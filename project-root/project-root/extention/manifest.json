{
  "manifest_version": 3,
  "name": "Advanced Misinformation Detector",
  "version": "2.0",
  "description": "Scans websites, audio, and video for misinformation with confidence metrics and sentiment analysis.",
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "tabs",
    "sidePanel",
    "contextMenus"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "http://localhost:5000/"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "MisinformationDetector"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ]
}